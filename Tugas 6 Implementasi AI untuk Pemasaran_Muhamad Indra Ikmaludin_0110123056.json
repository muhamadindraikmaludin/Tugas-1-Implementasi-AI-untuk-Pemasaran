    {
      "parameters": {
        "jsCode": "// 1. Ambil semua data dari input (Google Sheets)\nconst items = $input.all();\n\n// 2. Looping untuk menghitung engagement di tiap baris\nconst result = items.map(item => {\n  // Ambil data dari kolom (pastikan nama kolom sama persis dengan di Sheets)\n  const likes = item.json['Likes'] || 0;\n  const comments = item.json['Comments'] || 0;\n  const shares = item.json['Shares'] || 0;\n\n  // Rumus engagement bobot NF Academy: likes + (comments * 2) + (shares * 3)\n  const engagementScore = likes + (comments * 2) + (shares * 3);\n\n  // Simpan hasil hitungan ke kolom baru bernama 'engagementScore'\n  item.json.engagementScore = engagementScore;\n  \n  return item;\n});\n\n// 3. Urutkan dari skor tertinggi ke terendah (Ranking)\nresult.sort((a, b) => b.json.engagementScore - a.json.engagementScore);\n\n// 4. Kembalikan data agar bisa lanjut ke node berikutnya\nreturn result;"
      },
