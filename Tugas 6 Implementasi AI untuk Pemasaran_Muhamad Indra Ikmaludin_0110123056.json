    {
      "parameters": {
        "jsCode": "// Mengemas Insight - Versi Perbaikan untuk Arfan Khoeri\nconst items = $input.all();\n\nif (!items || items.length === 0) {\n  return [{ json: { message: '❌ Tidak ada data untuk dianalisis' } }];\n}\n\n// 1. Kelompokkan data berdasarkan Jam Posting (karena di Sheet ada banyak data per jam)\nconst groups = {};\n\nitems.forEach(item => {\n  const data = item.json;\n  const jam = data['Jam Posting'];\n  \n  if (!groups[jam]) {\n    groups[jam] = {\n      jam: jam,\n      likes: 0,\n      comments: 0,\n      shares: 0,\n      platform: data['Platform'] || 'Instagram',\n      count: 0\n    };\n  }\n  \n  // Mengambil angka dari Sheets (memastikan bukan teks kosong)\n  groups[jam].likes += parseFloat(data['Likes'] || 0);\n  groups[jam].comments += parseFloat(data['Comments'] || 0);\n  groups[jam].shares += parseFloat(data['Shares'] || 0);\n  groups[jam].count += 1;\n});\n\n// 2. Hitung Rata-rata & Engagement Score (Rumus Bobot NF: L + C*2 + S*3)\nconst results = Object.values(groups).map(g => {\n  const avgLikes = g.likes / g.count;\n  const avgComments = g.comments / g.count;\n  const avgShares = g.shares / g.count;\n  const score = avgLikes + (avgComments * 2) + (avgShares * 3);\n  \n  return {\n    jam: g.jam,\n    score: score.toFixed(0),\n    avgLikes: avgLikes.toFixed(0),\n    avgComments: avgComments.toFixed(0),\n    avgShares: avgShares.toFixed(0),\n    platform: g.platform,\n    totalPost: g.count\n  };\n});\n\n// 3. Urutkan berdasarkan Skor Tertinggi (Ranking)\nresults.sort((a, b) => b.score - a.score);\n\n// 4. Format Pesan Telegram (Copy-paste style NF Academy)\nlet message = '📊 *HASIL ANALISIS WAKTU POSTING TERBAIK*\\n';\nmessage += '━━━━━━━━━━━━━━━━━━━━━━━━\\n\\n';\nmessage += '🏆 *TOP 5 JAM TERBAIK*:\\n\\n';\n\nresults.slice(0, 5).forEach((item, index) => {\n  const medal = index === 0 ? '🥇' : (index === 1 ? '🥈' : (index === 2 ? '🥉' : (index + 1) + '.' ));\n  \n  message += `${medal} *JAM ${item.jam}:00*\\n`;\n  message += `📈 Avg Engagement: *${item.score}*\\n`;\n  message += `❤️ Avg Likes: ${item.avgLikes}\\n`;\n  message += `💬 Avg Comments: ${item.avgComments}\\n`;\n  message += `🔄 Avg Shares: ${item.avgShares}\\n`;\n  message += `📱 Platform: ${item.platform}\\n`;\n  message += `📊 Total Post: ${item.totalPost} post\\n`;\n  message += `⭐ SANGAT DIREKOMENDASIKAN\\n\\n`;\n});\n\nmessage += '🚀 _Gunakan insight ini untuk meningkatkan jangkauan konten Kaffe Tropikal Healing!_';\n\nreturn [{ json: { message } }];"
      },
